# ============================================================
# Localine – environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=localine

# ── Application ───────────────────────────────────────────────
NODE_ENV=development

# Allow / disallow new account creation through the web UI and API.
# Set to "false" to prevent public registrations.
SIGNUPS_ENABLED=true

# ── Sessions ─────────────────────────────────────────────────
# How long (in days) a session token remains valid for normal requests.
# After this window the client must call POST /api/sessions/refresh.
# Default: 14
SESSION_EXPIRES_DAYS=14

# How long (in days) a token can still be refreshed after it has expired.
# Once this window closes the user must log in again.
# Default: 30
SESSION_REFRESH_EXPIRES_DAYS=30

# Number of trusted reverse-proxy hops in front of the application.
# Used to correctly extract the real client IP from x-forwarded-for.
# Set to 1 if you have a single load-balancer/reverse-proxy (Nginx, Caddy, …).
# Set to 2 if there are two layers (e.g. a CDN + a load-balancer), etc.
# Setting this too low lets clients spoof their IP; setting it too high causes
# proxy IPs to be logged instead of the real client IP.
# Default: 1
TRUSTED_PROXY_COUNT=1

# ── Optional: Redis cache ─────────────────────────────────────
# When set, validated session payloads are cached in Redis instead of the
# built-in in-process Map.  Recommended for multi-instance deployments.
# Requires: npm install ioredis
#
# REDIS_URL=redis://localhost:6379

# ── Optional: IP Geolocation ─────────────────────────────────
# When set to "true", the server will look up city + country for each new
# session using ip-api.com (free tier, no API key required).
# Leave unset or set to "false" to disable (default).
#
# GEOIP_ENABLED=true
